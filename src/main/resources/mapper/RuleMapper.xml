<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 规则管理 SQL 映射，对应接口 com.znty.sirm.mapper.RuleMapper -->
<mapper namespace="com.znty.sirm.mapper.RuleMapper">
    <!-- 规则管理 mapper，对应表：rule_definition（规则定义）、rule_param（规则参数）、rule_param_option（参数选项）、rule_category（规则分类）、rule_preset_option_set（预设选项集）、rule_preset_option_item（预设选项明细），提供风控规则的 CRUD 及参数/选项管理功能 -->

    <!-- ==================== 规则定义（rule_definition） ==================== -->

    <!-- 分页查询规则列表，按创建时间倒序 -->
    <select id="queryRulePage" resultType="com.znty.sirm.model.RuleDefinitionBo">
        SELECT id
               ,rule_name
               ,description
               ,category_code
               ,script
               ,status
               ,deleted_flag
               ,crte_time
               ,updt_time
        FROM rule_definition
        <where>
            IFNULL(deleted_flag, 0) = 0
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    rule_name LIKE CONCAT('%', #{keyword}, '%')
                    OR description LIKE CONCAT('%', #{keyword}, '%')
                    OR EXISTS (
                        SELECT 1 FROM rule_param p
                        WHERE p.rule_id = rule_definition.id
                        AND (p.param_name LIKE CONCAT('%', #{keyword}, '%')
                             OR p.param_label LIKE CONCAT('%', #{keyword}, '%'))
                    )
                )
            </if>
        </where>
        ORDER BY crte_time DESC
                 ,id DESC
    </select>

    <!-- 按主键查询单条规则（仅未删除记录） -->
    <select id="queryRuleById" resultType="com.znty.sirm.model.RuleDefinitionBo">
        SELECT id
               ,rule_name
               ,description
               ,category_code
               ,script
               ,status
               ,deleted_flag
               ,crte_time
               ,updt_time
        FROM rule_definition
        WHERE id = #{id} AND IFNULL(deleted_flag, 0) = 0
        LIMIT 1
    </select>

    <!-- 按 ID 列表批量查询规则（用于关联查询，避免逐条查询的 N+1 问题） -->
    <select id="queryRuleByIds" resultType="com.znty.sirm.model.RuleDefinitionBo">
        SELECT id
               ,rule_name
               ,description
               ,category_code
               ,script
               ,status
               ,deleted_flag
               ,crte_time
               ,updt_time
        FROM rule_definition
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach>
        AND IFNULL(deleted_flag, 0) = 0
    </select>

    <!-- 新增规则，主键自增回填到实体 id 属性 -->
    <insert id="addRule" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO rule_definition (rule_name
                                    ,description
                                    ,category_code
                                    ,script
                                    ,status
                                    ,deleted_flag
                                    ,crte_time
                                    ,updt_time)
        VALUES (#{ruleName}
               ,#{description}
               ,#{categoryCode}
               ,#{script}
               ,#{status}
               ,#{deletedFlag}
               ,NOW()
               ,NOW())
    </insert>

    <!-- 按主键更新规则字段（仅未删除记录，避免更新已删除数据） -->
    <update id="editRule">
        UPDATE rule_definition
        SET rule_name = #{ruleName}
            ,description = #{description}
            ,category_code = #{categoryCode}
            ,script = #{script}
            ,status = #{status}
            ,updt_time = NOW()
        WHERE id = #{id} AND IFNULL(deleted_flag, 0) = 0
    </update>

    <!-- 仅更新规则启用状态 -->
    <update id="editRuleStatus">
        UPDATE rule_definition SET status = #{status}
                                   ,updt_time = NOW()
        WHERE id = #{id} AND IFNULL(deleted_flag, 0) = 0
    </update>

    <!-- 软删除：将 deleted_flag 置为 1，保留数据不物理删除 -->
    <update id="deleteRuleSoft">
        UPDATE rule_definition SET deleted_flag = 1
                                   ,updt_time = NOW()
        WHERE id = #{id} AND IFNULL(deleted_flag, 0) = 0
    </update>

    <!-- ==================== 规则参数（rule_param） ==================== -->

    <!-- 按规则 ID 查询该规则的所有参数，按排序号升序 -->
    <select id="queryParamsByRuleId" resultType="com.znty.sirm.model.RuleParamBo">
        SELECT id
               ,rule_id
               ,param_name
               ,param_label
               ,param_type
               ,required
               ,sort_no
               ,crte_time
               ,updt_time
        FROM rule_param WHERE rule_id = #{ruleId}
        ORDER BY sort_no ASC
                 ,id ASC
    </select>

    <!-- 按规则 ID 列表批量查询参数（用于规则列表页批量加载，避免 N+1） -->
    <select id="queryParamsByRuleIds" resultType="com.znty.sirm.model.RuleParamBo">
        SELECT id
               ,rule_id
               ,param_name
               ,param_label
               ,param_type
               ,required
               ,sort_no
               ,crte_time
               ,updt_time
        FROM rule_param WHERE rule_id IN
        <foreach collection="ruleIds" item="ruleId" open="(" separator="," close=")">#{ruleId}</foreach>
        ORDER BY rule_id ASC
                 ,sort_no ASC
                 ,id ASC
    </select>

    <!-- 新增规则参数，主键自增回填 -->
    <insert id="addParam" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO rule_param (rule_id
                               ,param_name
                               ,param_label
                               ,param_type
                               ,required
                               ,sort_no
                               ,crte_time
                               ,updt_time)
        VALUES (#{ruleId}
               ,#{paramName}
               ,#{paramLabel}
               ,#{paramType}
               ,#{required}
               ,#{sortNo}
               ,NOW()
               ,NOW())
    </insert>

    <!-- 按规则 ID 删除该规则下的所有参数（编辑保存时全量替换的前置清理） -->
    <delete id="deleteParamsByRuleId">
        DELETE FROM rule_param WHERE rule_id = #{ruleId}
    </delete>

    <!-- ==================== 规则参数选项（rule_param_option） ==================== -->

    <!-- 按参数 ID 列表批量查询选项（用于规则详情批量加载，避免 N+1） -->
    <select id="queryOptionsByParamIds" resultType="com.znty.sirm.model.RuleParamOptionBo">
        SELECT id
               ,param_id
               ,option_value
               ,option_label
               ,sort_no
               ,crte_time
               ,updt_time
        FROM rule_param_option WHERE param_id IN
        <foreach collection="paramIds" item="paramId" open="(" separator="," close=")">#{paramId}</foreach>
        ORDER BY param_id ASC
                 ,sort_no ASC
                 ,id ASC
    </select>

    <!-- 新增参数选项 -->
    <insert id="addParamOption" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO rule_param_option (param_id
                                      ,option_value
                                      ,option_label
                                      ,sort_no
                                      ,crte_time
                                      ,updt_time)
        VALUES (#{paramId}
               ,#{optionValue}
               ,#{optionLabel}
               ,#{sortNo}
               ,NOW()
               ,NOW())
    </insert>

    <!-- 按规则 ID 级联删除该规则下所有参数的选项（通过子查询匹配 param_id） -->
    <delete id="deleteParamOptionsByRuleId">
        DELETE FROM rule_param_option WHERE param_id IN (
            SELECT id FROM rule_param WHERE rule_id = #{ruleId}
        )
    </delete>

    <!-- ==================== 规则分类（rule_category） ==================== -->

    <!-- 查询所有启用的规则分类（enabled 为 null 时默认为启用） -->
    <select id="queryCategoryList" resultType="com.znty.sirm.model.RuleCategoryBo">
        SELECT id
               ,category_code
               ,category_name
               ,sort_no
               ,enabled
               ,crte_time
               ,updt_time
        FROM rule_category WHERE IFNULL(enabled, 1) = 1
        ORDER BY sort_no ASC
                 ,id ASC
    </select>

    <!-- ==================== 预设选项集 & 预设选项明细 ==================== -->

    <!-- 查询所有启用的预设选项集 -->
    <select id="queryPresetSetList" resultType="com.znty.sirm.model.RulePresetOptionSetBo">
        SELECT id
               ,set_name
               ,sort_no
               ,enabled
               ,crte_time
               ,updt_time
        FROM rule_preset_option_set WHERE IFNULL(enabled, 1) = 1
        ORDER BY sort_no ASC
                 ,id ASC
    </select>

    <!-- 按选项集 ID 列表批量查询预设选项明细 -->
    <select id="queryPresetItemList" resultType="com.znty.sirm.model.RulePresetOptionItemBo">
        SELECT id
               ,set_id
               ,option_value
               ,option_label
               ,sort_no
        FROM rule_preset_option_item WHERE set_id IN
        <foreach collection="setIds" item="setId" open="(" separator="," close=")">#{setId}</foreach>
        ORDER BY set_id ASC
                 ,sort_no ASC
                 ,id ASC
    </select>
</mapper>
