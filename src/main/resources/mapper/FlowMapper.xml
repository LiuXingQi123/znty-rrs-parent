    <!-- ==================== 归一化表 SELECT（用于事件记录：捕获删除前的旧行） ==================== -->

    <!-- 查询指定版本的流程节点列表。 -->
    <select id="queryFlowNodeListByVersionId" resultType="com.znty.sirm.entity.bo.FlowNodeBo">
        SELECT * FROM wf_flow_node WHERE version_id = #{versionId}</select>

    <!-- 查询指定版本的审批配置列表。 -->
    <select id="queryApprovalConfigListByVersionId" resultType="com.znty.sirm.entity.bo.NodeApprovalConfigBo">
        SELECT c.* FROM wf_node_approval_config c
        INNER JOIN wf_flow_node n ON n.id = c.node_id
        WHERE n.version_id = #{versionId}
    </select>

    <!-- 查询指定版本的审批处理人明细列表 -->
    <select id="queryApprovalHandlerListByVersionId" resultType="com.znty.sirm.entity.bo.NodeApprovalHandlerBo">
        SELECT h.*
        FROM wf_node_approval_handler h
        INNER JOIN wf_node_approval_config c ON c.id = h.approval_config_id
        INNER JOIN wf_flow_node n ON n.id = c.node_id
        WHERE n.version_id = #{versionId}
        ORDER BY h.approval_config_id ASC
                 ,h.sort_order ASC
                 ,h.id ASC
    </select>

    <!-- 查询指定版本的自动任务配置列表。 -->
    <select id="queryAutoConfigListByVersionId" resultType="com.znty.sirm.entity.bo.NodeAutoConfigBo">
        SELECT c.* FROM wf_node_auto_config c
        INNER JOIN wf_flow_node n ON n.id = c.node_id
        WHERE n.version_id = #{versionId}
    </select>

    <!-- 查询指定版本的通知配置列表。 -->
    <select id="queryNotifyConfigListByVersionId" resultType="com.znty.sirm.entity.bo.NodeNotifyConfigBo">
        SELECT c.* FROM wf_node_notify_config c
        INNER JOIN wf_flow_node n ON n.id = c.node_id
        WHERE n.version_id = #{versionId}
    </select>

    <!-- 查询指定版本的条件配置列表。 -->
    <select id="queryConditionConfigListByVersionId" resultType="com.znty.sirm.entity.bo.NodeConditionConfigBo">
        SELECT c.* FROM wf_node_condition_config c
        INNER JOIN wf_flow_node n ON n.id = c.node_id
        WHERE n.version_id = #{versionId}
    </select>

    <!-- 查询指定版本的流程连线列表。 -->
    <select id="queryFlowEdgeListByVersionId" resultType="com.znty.sirm.entity.bo.FlowEdgeBo">
        SELECT * FROM wf_flow_edge WHERE version_id = #{versionId}</select>

    <!-- 查询指定版本的连线条件规则列表。 -->
    <select id="queryCondRuleListByVersionId" resultType="com.znty.sirm.entity.bo.EdgeCondRuleBo">
        SELECT r.* FROM wf_edge_cond_rule r
        INNER JOIN wf_flow_edge e ON e.id = r.edge_id
        WHERE e.version_id = #{versionId}
    </select>

