<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.znty.sirm.mapper.SysAttachmentMapper">

    <!-- 新增附件关联记录 -->
    <insert id="addAttachment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_attachment (
            table_name
            ,main_id
            ,attachment_category
            ,file_type
            ,original_file_name
            ,new_file_name
            ,file_size
            ,content_type
            ,full_url
            ,file_name
            ,uploader_id
            ,is_deleted
            ,crte_time
            ,updt_time
        ) VALUES (
            #{tableName}
            ,#{mainId}
            ,#{attachmentCategory}
            ,#{fileType}
            ,#{originalFileName}
            ,#{newFileName}
            ,#{fileSize}
            ,#{contentType}
            ,#{fullUrl}
            ,#{fileName}
            ,#{uploaderId}
            ,0
            ,NOW()
            ,NOW()
        )
    </insert>

    <!-- 按调库日志 ID 查询附件列表 -->
    <select id="queryAttachmentList" resultType="com.znty.sirm.model.SysAttachmentDto">
        SELECT id
               ,attachment_category
               ,original_file_name
               ,file_type
               ,file_size
               ,content_type
               ,full_url
        FROM sys_attachment
        WHERE table_name = 'ip_adjust_log'
          AND main_id = #{adjustLogId}
          AND is_deleted = 0
        ORDER BY id ASC
    </select>

    <!-- 按附件 ID 查询附件 -->
    <select id="queryAttachmentById" resultType="com.znty.sirm.model.SysAttachmentBo">
        SELECT *
        FROM sys_attachment
        WHERE id = #{id}
          AND is_deleted = 0
    </select>

    <!-- 按附件 ID 列表查询附件 -->
    <select id="queryAttachmentListByIds" resultType="com.znty.sirm.model.SysAttachmentBo">
        SELECT *
        FROM sys_attachment
        WHERE is_deleted = 0
          AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 逻辑删除指定调库日志下的附件 -->
    <update id="deleteAttachmentByIdsList">
        UPDATE sys_attachment
        SET is_deleted = 1
            ,updt_time = NOW()
        WHERE table_name = 'ip_adjust_log'
          AND main_id = #{adjustLogId}
          AND is_deleted = 0
          AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
