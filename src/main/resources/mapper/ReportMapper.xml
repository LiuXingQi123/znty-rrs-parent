<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.znty.rrs.mapper.ReportMapper">
    <!-- 报告库 mapper，对应表：rrs_report_in / rrs_report_out，提供内部 / 外部报告分页查询功能 -->

    <!-- 分页查询内部报告库列表 -->
    <select id="queryInReportPage" resultType="com.znty.rrs.entity.report.ReportDto">
        SELECT id
               ,author_name
               ,report_title
               ,report_type
               ,security_code
               ,company_code
               ,security_type
               ,data_source
               ,crte_time
        FROM rrs_report_in
        <where>
            is_deleted = 0
            <if test="reportTitle != null and reportTitle != ''">
                AND report_title LIKE CONCAT('%', #{reportTitle}, '%')
            </if>
            <if test="securityCode != null and securityCode != ''">
                AND security_code LIKE CONCAT('%', #{securityCode}, '%')
            </if>
            <if test="reportType != null and reportType != ''">
                AND report_type = #{reportType}
            </if>
            <if test="crteTimeStart != null and crteTimeStart != ''">
                AND crte_time &gt;= #{crteTimeStart}
            </if>
            <if test="crteTimeEnd != null and crteTimeEnd != ''">
                AND crte_time &lt;= CONCAT(#{crteTimeEnd}, ' 23:59:59')
            </if>
        </where>
        ORDER BY crte_time DESC
                 ,id DESC
    </select>

    <!-- 分页查询外部报告库列表 -->
    <select id="queryOutReportPage" resultType="com.znty.rrs.entity.report.ReportDto">
        SELECT id
               ,author_name
               ,source_org_name
               ,report_title
               ,report_type
               ,security_code
               ,company_code
               ,security_type
               ,data_source
               ,crte_time
        FROM rrs_report_out
        <where>
            is_deleted = 0
            <if test="reportTitle != null and reportTitle != ''">
                AND report_title LIKE CONCAT('%', #{reportTitle}, '%')
            </if>
            <if test="securityCode != null and securityCode != ''">
                AND security_code LIKE CONCAT('%', #{securityCode}, '%')
            </if>
            <if test="reportType != null and reportType != ''">
                AND report_type = #{reportType}
            </if>
            <if test="crteTimeStart != null and crteTimeStart != ''">
                AND crte_time &gt;= #{crteTimeStart}
            </if>
            <if test="crteTimeEnd != null and crteTimeEnd != ''">
                AND crte_time &lt;= CONCAT(#{crteTimeEnd}, ' 23:59:59')
            </if>
        </where>
        ORDER BY crte_time DESC
                 ,id DESC
    </select>

    <!-- 按内部报告 ID 批量查询报告附件 -->
    <select id="queryInReportAttachmentList" resultType="com.znty.rrs.entity.sysattachment.SysAttachmentDto">
        SELECT id
               ,main_id
               ,attachment_category
               ,original_file_name
               ,file_type
               ,file_size
               ,content_type
               ,full_url
        FROM sys_attachment
        WHERE table_name = 'rrs_report_in'
          AND attachment_category = 'report_in'
          AND is_deleted = 0
          AND main_id IN
        <foreach collection="reportIds" item="reportId" open="(" separator="," close=")">
            #{reportId}
        </foreach>
        ORDER BY main_id ASC
                 ,id ASC
    </select>

    <!-- 按外部报告 ID 批量查询报告附件 -->
    <select id="queryOutReportAttachmentList" resultType="com.znty.rrs.entity.sysattachment.SysAttachmentDto">
        SELECT id
               ,main_id
               ,attachment_category
               ,original_file_name
               ,file_type
               ,file_size
               ,content_type
               ,full_url
        FROM sys_attachment
        WHERE table_name = 'rrs_report_out'
          AND attachment_category = 'report_out'
          AND is_deleted = 0
          AND main_id IN
        <foreach collection="reportIds" item="reportId" open="(" separator="," close=")">
            #{reportId}
        </foreach>
        ORDER BY main_id ASC
                 ,id ASC
    </select>

    <!-- 新增内部报告记录 -->
    <insert id="addInReport" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO rrs_report_in (
            author_name
            ,report_title
            ,report_type
            ,security_code
            ,company_code
            ,security_type
            ,data_source
            ,is_deleted
            ,crte_time
            ,updt_time
        ) VALUES (
            #{authorName}
            ,#{reportTitle}
            ,#{reportType}
            ,#{securityCode}
            ,#{companyCode}
            ,#{securityType}
            ,#{dataSource}
            ,0
            ,NOW()
            ,NOW()
        )
    </insert>
</mapper>
