<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.znty.rrs.mapper.MySecurityPoolMapper">
    <!-- 我的证券池 mapper，对应表：my_security_pool（用户自选证券），提供证券收藏的添加、软删除及查询功能 -->

    <!-- 添加证券到我的证券池 -->
    <insert id="addSecurityToMyPool" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO my_security_pool (security_code
                                     ,security_type
                                     ,market
                                     ,user_id
                                     ,status
                                     ,remark
                                     ,create_time
                                     ,update_time)
        VALUES (#{securityCode}
               ,#{securityType}
               ,#{market}
               ,#{userId}
               ,'use'
               ,#{remark}
               ,NOW()
               ,NOW())
    </insert>

    <!-- 从我的证券池移除（软删除） -->
    <update id="deleteSecurityFromMyPool">
        UPDATE my_security_pool
        SET status = 'del'
            ,update_time = NOW()
        WHERE user_id = #{userId}
          AND security_code = #{securityCode}
          AND status = 'use'
    </update>

    <!-- 查询用户某证券的有效收藏记录 -->
    <select id="queryByUserAndCode" resultType="com.znty.rrs.entity.bo.MySecurityPoolBo">
        SELECT id
               ,security_code
               ,security_type
               ,market
               ,user_id
               ,status
               ,remark
               ,create_time
               ,update_time
        FROM my_security_pool
        WHERE user_id = #{userId}
          AND security_code = #{securityCode}
          AND status = 'use'
        LIMIT 1
    </select>

    <!-- 批量查询用户已收藏的证券代码列表 -->
    <select id="queryFavoritedCodeList" resultType="java.lang.String">
        SELECT security_code
        FROM my_security_pool
        WHERE user_id = #{userId}
          AND status = 'use'
    </select>

</mapper>
